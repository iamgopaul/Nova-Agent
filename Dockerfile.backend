FROM python:3.12-slim

WORKDIR /app

# System libraries needed by OpenCV, PortAudio, and psycopg2
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    libsndfile1 \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install Python package (core + document generation extras).
# Heavy optional extras (imagegen, musicgen, speakerid) are excluded from
# the Docker image — they require large model weights best kept on the host.
COPY pyproject.toml .
COPY gaaia/ gaaia/
COPY config/ config/
COPY scripts/ scripts/

RUN pip install --no-cache-dir -e ".[docgen]"

# Runtime data lives on a named volume mounted at /app/data
ENV GAAIA_DATA_DIR=/app/data

EXPOSE 8765

CMD ["uvicorn", "gaaia.server.main:create_app", \
     "--factory", "--host", "0.0.0.0", "--port", "8765", \
     "--workers", "1"]
