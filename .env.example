# GAAIA — Environment Variables
# Copy to .env and fill in values. Never commit .env.
#
# GAAIA runs 100% locally — no paid services required for the core MVP.

# Next.js API proxies use this to reach the FastAPI server. Must be the server
# ROOT only (e.g. http://127.0.0.1:8765) — do NOT add /api.
# GAAIA_API_BASE=http://127.0.0.1:8765

# ── Database (optional — defaults to SQLite) ──────────────────────────────────
# When set, GAAIA uses PostgreSQL with separate auth & data schemas.
# Run scripts/init_db.sql first to create the schemas.
# DATABASE_URL=postgresql+psycopg2://gaaia:gaaia_pw@localhost:5432/gaaia

# ── Resend (email OTP & notifications) ───────────────────────────────────────
# Sign up free at https://resend.com — 100 emails/day on the free tier.
# Required for email 2FA and scheduled task email notifications.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# Create products + prices at https://dashboard.stripe.com/products
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs for each plan/interval (create in Stripe dashboard):
# STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_TEAMS_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_TEAMS_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── App URL (used for Stripe redirect URLs) ───────────────────────────────────
# APP_URL=http://localhost:3000

# Optional: override Ollama host (default: http://localhost:11434)
# Only set this if Ollama is running on a different machine.
# OLLAMA_HOST=http://localhost:11434

# Optional: TMDB API key for richer movie/series data.
# Free to register at https://www.themoviedb.org (email only, no credit card).
# Leave blank to use DuckDuckGo-based movie search instead.
# TMDB_API_KEY=

# Optional: ElevenLabs API key for natural neural TTS voice.
# Free tier: 10,000 characters/month. Sign up at https://elevenlabs.io
# Without this, Nova falls back to the macOS `say` command (Flo voice).
# ELEVENLABS_API_KEY=

# Optional: Brave Search API key for fast, reliable web search.
# Free tier: 2,000 queries/month. Sign up at https://brave.com/search/api/
# When set, Brave is used as primary search engine.
# DuckDuckGo remains as fallback when this is blank.
# BRAVE_SEARCH_API_KEY=

# ── Social OAuth (optional) ───────────────────────────────────────────────────
# Google: console.cloud.google.com → APIs & Services → Credentials
#   Authorized redirect URI: http://127.0.0.1:8765/auth/oauth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub: github.com/settings/developers → OAuth Apps → New OAuth App
#   Authorization callback URL: http://127.0.0.1:8765/auth/oauth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional: MusicGen (beat generation) device — auto|cpu|mps|cuda. Use cpu on Apple
# Silicon if MPS runs out of memory (long clips are heavy on GPU RAM).
# Install deps: pip install -e ".[musicgen]"
# NOVA_MUSIC_DEVICE=auto
